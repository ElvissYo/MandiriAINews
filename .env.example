# Shared Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Public client key. Only copy this value to mobile_app/.env.
SUPABASE_ANON_KEY=your-anon-key

# Backend-only secrets. Never copy these values into mobile_app/.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEWS_API_KEY=your-news-provider-key

# Extraction: auto | newsapi | rss | dummy
NEWS_SOURCE=auto
NEWS_API_URL=https://newsapi.org/v2/everything
NEWS_API_QUERY=Indonesia OR ASEAN
NEWS_API_LANGUAGE=en
NEWS_RSS_URLS=https://news.google.com/rss?hl=id&gl=ID&ceid=ID:id
NEWS_REQUEST_TIMEOUT=12

# Optional OpenAI-compatible summary endpoint. Leave blank for local fallback.
LLM_SUMMARY_API_URL=
LLM_SUMMARY_API_KEY=
LLM_SUMMARY_MODEL=
